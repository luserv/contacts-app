#DATABASE_URL=postgresql://postgres:admin@localhost:5432/contacts
DATABASE_URL=postgresql://user:password@localhost:5432/contacts_db

# DATABASE_MODE: choose 'postgres' (remote Render) or 'sqlite' (local)
# postgres - Uses Prisma + PostgreSQL (remote)
# sqlite  - Uses better-sqlite3 + local SQLite file (./data/contacts.db)
DATABASE_MODE=postgres

EXPO_PUBLIC_API_URL=http://localhost:8081
